# Copy to .env and fill in. .env is gitignored; the key never enters source.
# tau2-bench uses litellm, so any OpenAI-compatible provider works.

# --- pick ONE provider style ---

# OpenAI:
# OPENAI_API_KEY=sk-...
# TAU2_MODEL=openai/gpt-4o-mini

# DashScope (通义千问, OpenAI-compatible endpoint):
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# TAU2_MODEL=openai/qwen-plus

# DeepSeek:
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# TAU2_MODEL=openai/deepseek-chat

# Which model the USER SIMULATOR uses (can be the same, cheaper is fine):
TAU2_USER_MODEL=
